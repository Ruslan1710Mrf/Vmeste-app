{
  "expo": {
    "name": "sng-community2",
    "slug": "sng-community2",
    "scheme": "vmeste",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vmeste.group",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.vmeste.group",
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1029398639222-pprhrr68eqdom87jdpaqt30beaaupp79"
        }
      ],
      "expo-apple-authentication",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vmeste запросит доступ к фото, чтобы вы могли добавить их в пост или профиль."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6b5068cd-22cd-431e-a463-176d0385be54"
      }
    }
  }
}
