# Ключ Anthropic — только для серверного прокси (не попадает в браузер)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Опционально: URL прокси в production (например Firebase Function или Express)
# EXPO_PUBLIC_AI_PROXY_URL=https://your-proxy.example.com

# Web Client ID для Google Sign-In (Firebase Console → Authentication → Google)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
