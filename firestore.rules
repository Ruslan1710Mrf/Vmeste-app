rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.city is string
        && request.resource.data.interests is list
        && request.resource.data.createdAt is timestamp;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /posts/{postId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId;
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    match /blocks/{blockId} {
      allow read: if request.auth != null
        && (resource.data.blockerId == request.auth.uid || resource.data.blockedId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.blockerId == request.auth.uid
        && request.resource.data.blockedId is string
        && blockId == request.resource.data.blockerId + '_' + request.resource.data.blockedId;
      allow delete: if request.auth != null && resource.data.blockerId == request.auth.uid;
      allow update: if false;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['post', 'user']
        && request.resource.data.targetId is string
        && request.resource.data.createdAt is string;
      allow read, update, delete: if false;
    }

    match /events/{eventId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId;
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !exists(/databases/$(database)/documents/meta/$(docId));
    }

    match /aiChats/{userId}/messages/{messageId} {
      allow read, create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role in ['user', 'assistant']
        && request.resource.data.content is string
        && request.resource.data.createdAt is string;
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /conversations/{convId} {
      allow get: if request.auth != null
        && (
          !exists(/databases/$(database)/documents/conversations/$(convId))
          || request.auth.uid in resource.data.participants
        );
      allow list: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && !exists(/databases/$(database)/documents/blocks/$(request.resource.data.participants[0] + '_' + request.resource.data.participants[1]))
        && !exists(/databases/$(database)/documents/blocks/$(request.resource.data.participants[1] + '_' + request.resource.data.participants[0]));
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.text is string
          && !exists(/databases/$(database)/documents/blocks/$(get(/databases/$(database)/documents/conversations/$(convId)).data.participants[0] + '_' + get(/databases/$(database)/documents/conversations/$(convId)).data.participants[1]))
          && !exists(/databases/$(database)/documents/blocks/$(get(/databases/$(database)/documents/conversations/$(convId)).data.participants[1] + '_' + get(/databases/$(database)/documents/conversations/$(convId)).data.participants[0]));
        allow update: if false;
        allow delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    match /mail/{docId} {
      allow read, write: if false;
    }
  }
}
